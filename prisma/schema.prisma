// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String             @id @default(uuid())
  wallet_address      String             @unique @db.VarChar(42)
  created_at          DateTime           @default(now()) @db.Timestamptz
  updated_at          DateTime           @default(now()) @db.Timestamptz
  scaffold_sessions   ScaffoldSession[]
  profiler_sessions   ProfilerSession[]
}

model ScaffoldSession {
  id              String   @id @default(uuid())
  user_id         String?  @map("user_id")
  config          Json     @db.JsonB
  contract_name   String   @db.VarChar(100)
  contract_type   String   @db.VarChar(50)
  oz_version      String   @default("5.x") @db.VarChar(10)
  warnings        Json?    @db.JsonB
  errors          Json?    @db.JsonB
  compile_success Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz

  user User? @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id], map: "idx_scaffold_user")
  @@map("scaffold_sessions")
}

model ProfilerSession {
  id               String        @id @default(uuid())
  user_id          String?       @map("user_id")
  user             User?         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  contract_address String        @db.VarChar(42)
  network          String        @default("polkadot-hub-testnet") @db.VarChar(50)
  abi              Json          @db.JsonB
  created_at       DateTime      @default(now()) @db.Timestamptz
  weight_results   WeightResult[]

  @@index([contract_address], map: "idx_profiler_address")
  @@map("profiler_sessions")
}

model WeightResult {
  id                 String          @id @default(uuid())
  session_id         String          @map("session_id")
  session            ProfilerSession @relation(fields: [session_id], references: [id], onDelete: Cascade)
  function_name      String          @db.VarChar(100)
  function_signature String          @db.VarChar(200)
  ref_time           BigInt?         // picoseconds
  proof_size         BigInt?         // bytes
  storage_deposit    BigInt?         // planck units
  evm_gas_estimate   BigInt?         // Sepolia EVM gas
  raw_response       Json?           // full RPC response for debugging
  measured_at        DateTime        @default(now()) @db.Timestamptz

  @@index([session_id], map: "idx_weight_session")
  @@map("weight_results")
}

model PublicBenchmark {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contract_type  String   @db.VarChar(50)
  function_name  String   @db.VarChar(100)
  avg_ref_time   BigInt?
  avg_proof_size BigInt?
  avg_evm_gas    BigInt?
  sample_count   Int      @default(1)
  last_updated   DateTime @default(now()) @db.Timestamptz

  @@index([contract_type, function_name], map: "idx_benchmarks_type")
  @@map("public_benchmarks")
}
